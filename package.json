{
  "name": "renovamen-blog",
  "private": true,
  "description": "Renovamen's blog, powered by VuePress 2, themed by Gungnir.",
  "license": "Apache-2.0",
  "author": "Renovamen <renovamenzxh@gmail.com>",
  "scripts": {
    "clean": "rimraf docs/.vuepress/.temp docs/.vuepress/.cache dist",
    "dev": "vuepress dev docs --clean-cache",
    "build": "yarn clean && vuepress build docs --clean-cache",
    "serve": "anywhere -h localhost -d dist"
  },
  "dependencies": {
    "vuepress-theme-gungnir": "2.0.0-alpha.14"
  },
  "devDependencies": {
    "anywhere": "^1.5.0",
    "rimraf": "^3.0.2",
    "vuepress": "^2.0.0-beta.35",
    "vuepress-vite": "2.0.0-beta.35",
    "vuepress-webpack": "2.0.0-beta.35"
  }
}
